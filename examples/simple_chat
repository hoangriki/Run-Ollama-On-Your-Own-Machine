📄 run.sh
```
#!/usr/bin/env bash

# Simple script to send a prompt to a local Ollama model
# Usage:
#   ./run.sh
#   ./run.sh "Your custom prompt here"

MODEL="qwen2.5"
DEFAULT_PROMPT_FILE="example_prompt.txt"

# If user passed a prompt as argument, use it
if [ "$1" != "" ]; then
  PROMPT="$1"
else
  # Otherwise read from example_prompt.txt
  if [ -f "$DEFAULT_PROMPT_FILE" ]; then
    PROMPT=$(cat "$DEFAULT_PROMPT_FILE")
  else
    echo "No prompt provided and example_prompt.txt not found."
    exit 1
  fi
fi

echo "Sending prompt to Ollama..."
echo "Model: $MODEL"
echo "Prompt: $PROMPT"
echo "----------------------------------"

curl http://localhost:11434/api/generate -d "{
  \"model\": \"$MODEL\",
  \"prompt\": \"$PROMPT\",
  \"stream\": false
}" | jq -r '.response'
```

⚠️ Requires jq for pretty output:
```
sudo apt install jq
```

Make executable:
chmod +x run.sh
